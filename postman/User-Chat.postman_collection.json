                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"amount\": 98000,\n  \"currency\": \"IQD\",\n  \"title\": \"عرض مقابل\",\n  \"details\": \"هذا آخر سعر\",\n  \"valid_until\": \"2026-12-31T12:00:00Z\",\n  \"body\": \"Counter offer submitted\"\n}"
                },
                "url": "{{base_url}}/api/user/chats/{{chat_id}}/messages/{{message_id}}/offer/counter"
              }
            },
            {
              "name": "Offer Thread History",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{user_token}}" },
                  { "key": "Accept", "value": "application/json" }
                ],
                "url": "{{base_url}}/api/user/chats/{{chat_id}}/offers/{{message_id}}/thread"
              }
            }
          ]
        },
        {
          "name": "Pin / Mute / Block",
          "item": [
