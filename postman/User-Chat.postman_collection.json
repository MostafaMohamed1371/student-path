                "url": "{{base_url}}/api/user/chats/{{chat_id}}/typing"
              }
            }
          ]
        },
        {
          "name": "Admin — List all (use admin_token)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/user/chats?per_page=20"
          }
        },
        {
          "name": "Admin — Reply text (use admin_token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message_type\": \"text\",\n  \"body\": \"مرحباً، كيف يمكننا مساعدتك؟\"\n}"
            },
            "url": "{{base_url}}/api/user/chats/{{chat_id}}/messages"
          }
        }
      ]
    },
