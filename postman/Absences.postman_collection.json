                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/students/{{student_id}}/daily-timeline?date={{timeline_date}}"
                    },
                    "description": "Returns student header + 4 milestones: morning_pickup_home, morning_arrive_school, evening_pickup_school, evening_arrive_home. Each has status, status_color, status_background_color, scheduled/actual times. Absence today marks all milestones absent (#D32F2F)."
                },
                {
                    "name": "GET /api/students/{id}/daily-timeline (today)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/students/{{student_id}}/daily-timeline"
                    }
                }
            ]
        },
        {
            "name": "Parent — Absences",
            "description": "Bearer: `token`. Parent can only manage own absences. Report requires subscribed driver.",
            "item": [
                {
                    "name": "POST /api/absences (report)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "  try {",
                                    "    const j = pm.response.json();",
                                    "    if (j.data && j.data.id) {",
                                    "      pm.collectionVariables.set('absence_id', String(j.data.id));",
                                    "    }",
                                    "  } catch (e) {}",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/api/absences",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"student_id\": {{student_id}},\n  \"start_date\": \"{{absence_start_date}}\",\n  \"end_date\": \"{{absence_end_date}}\",\n  \"reason\": \"{{absence_reason}}\",\n  \"notes\": \"Family trip — notify driver and school.\"\n}"
                        }
                    },
                    "description": "Reason must be enum code from meta (`medical`, `travel`, `family`, `other`). Resolves subscribed driver, sends in-app notifications, marks trip students absent."
                },
                {
                    "name": "GET /api/absences (all mine)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/absences?per_page=20"
                    }
                },
                {
                    "name": "GET /api/absences (by student)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/absences?student_id={{student_id}}&per_page=20"
                    }
                },
                {
                    "name": "GET /api/absences (by date range)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/absences?from={{absence_start_date}}&to={{absence_end_date}}&student_id={{student_id}}"
                    }
                },
                {
                    "name": "GET /api/absences (single day)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/absences?date={{absence_start_date}}&student_id={{student_id}}"
                    }
                },
                {
                    "name": "GET /api/absences/{id}",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/absences/{{absence_id}}"
                    }
                },
                {
                    "name": "PUT /api/absences/{id}",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/api/absences/{{absence_id}}",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"start_date\": \"{{absence_start_date}}\",\n  \"end_date\": \"{{absence_end_date}}\",\n  \"reason\": \"medical\",\n  \"notes\": \"Updated via PUT.\"\n}"
                        }
                    },
                    "description": "Owner only. Does not re-notify driver or re-apply trip roster."
                },
                {
                    "name": "PATCH /api/absences/{id}",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/api/absences/{{absence_id}}",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"reason\": \"family\",\n  \"notes\": \"Updated via PATCH.\"\n}"
                        }
                    }
                },
                {
                    "name": "DELETE /api/absences/{id}",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/absences/{{absence_id}}"
                    },
                    "description": "Owner only."
                }
            ]
        },
        {
            "name": "Enable arrival alerts",
            "description": "Mobile button **تفعيل تنبيهات الوصول** (daily timeline). Run requests **1 → 4 in order** after **Auth → verify-otp (guardian)**.\n\n1. Resolve today's active `trip_id` for the student.\n2. Register FCM device token.\n3. Enable `tripNotifications.busArrival` (and related trip toggles).\n4. Subscribe to the trip FCM topic for live arrival pushes.\n\nSet collection variable `fcm_token` from Firebase SDK before step 2. Requires an active trip for the student.",
            "item": [
                {
                    "name": "1. GET /api/trips/active (student → sets trip_id)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  try {",
                                    "    const j = pm.response.json();",
                                    "    let trip = j.data && j.data.trip;",
                                    "    if (!trip && j.data && Array.isArray(j.data.active) && j.data.active.length) {",
                                    "      trip = j.data.active[0].trip;",
                                    "    }",
                                    "    let id = trip && trip.id;",
                                    "    if (id !== undefined && id !== null && id !== '') {",
                                    "      id = String(id);",
                                    "      if (!id.startsWith('TRP-')) { id = 'TRP-' + id; }",
                                    "      pm.collectionVariables.set('trip_id', id);",
                                    "    }",
                                    "  } catch (e) {}",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/trips/active?student_id={{student_id}}"
                    }
                },
                {
                    "name": "2. POST /api/user/fcm-token",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/api/user/fcm-token",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"token\": \"{{fcm_token}}\",\n  \"platform\": \"android\",\n  \"device_id\": \"postman-absences-collection\"\n}"
                        }
                    },
                    "description": "Register device for push. Replace `fcm_token` collection variable with the real Firebase registration token from the mobile app."
                },
                {
                    "name": "3. PUT /api/user/settings/notifications",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/api/user/settings/notifications",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"tripNotifications\": {\n    \"busMovement\": true,\n    \"busArrival\": true,\n    \"returnTrip\": true,\n    \"driverDelay\": true,\n    \"sos\": true\n  }\n}"
                        }
                    },
                    "description": "Enables arrival-related pushes. `TRIP_STUDENT_ARRIVED` maps to `busArrival` in server config."
                },
                {
                    "name": "4. POST /api/trip-tracking/topics/subscribe",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/api/trip-tracking/topics/subscribe",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"trip_id\": \"{{trip_id}}\",\n  \"token\": \"{{fcm_token}}\"\n}"
                        }
                    },
                    "description": "Subscribes the device to the trip topic (`trip_{id}`). Uses `trip_id` from step 1 and `fcm_token` from step 2."
                }
            ]
        },
        {
            "name": "Driver — Absences",
            "description": "Bearer: `driver_token`. Lists absences assigned to the logged-in driver.",
            "item": [
                {
                    "name": "GET /api/absences (driver — all assigned)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
