                        "url": "{{base_url}}/api/absences?date={{absence_start_date}}"
                    }
                },
                {
                    "name": "GET /api/absences/{id} (driver)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{driver_token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/absences/{{absence_id}}"
                    },
                    "description": "Allowed when `absence.driver_id` matches the driver's linked account."
                },
                {
                    "name": "GET /api/in-app-notifications (driver — absence alerts)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{driver_token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/in-app-notifications?unread_only=1&per_page=20"
                    },
                    "description": "After parent reports absence, driver receives notification with `data.type`: `ABSENCE`."
                }
            ]
        }
    ]
}
