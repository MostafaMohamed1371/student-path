                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{driver_token}}"
                            }
                        ],
                        "url": "{{base_url}}/api/absences?per_page=20"
                    }
                },
                {
                    "name": "GET /api/absences (driver — by date)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{driver_token}}"
                            }
