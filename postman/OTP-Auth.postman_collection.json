              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/user/profile"
          }
        }
      ]
    },
    {
      "name": "Bus Services",
      "description": "Uses the authenticated user’s **driver** account (no school-admin scoping). **GET/POST/PUT/DELETE** `my-bus` require a linked driver and apply only to that driver’s bus.",
