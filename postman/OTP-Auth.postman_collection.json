    {
      "name": "School Services",
      "description": "**Create & delete** schools: use header `Authorization: Bearer {{admin_token}}` and set `admin_token` to a **Sanctum** token for an `is_admin` user. **List / show / update** a school: non-admins only see and may update **their** school; admins see all. After **verify-otp**, the collection saves `{{token}}` (not `admin_token`). Paste an admin token into `admin_token` manually, or use `php artisan tinker` / Personal Access Token for the seeded admin.",
      "item": [
        {
          "name": "GET /api/schools",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/schools"
          }
        },
        {
          "name": "GET /api/schools/{school}",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/schools/{{school_id}}"
          }
        },
        {
          "name": "POST /api/schools (admin only)",
          "description": "Requires `admin_token` (is_admin user). Returns 403 if you use only `token` from a non-admin user.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "schoolNameAr", "value": "مدرسة النور الابتدائية", "type": "text" },
                { "key": "schoolNameEn", "value": "Al Noor Primary School", "type": "text" },
                { "key": "province", "value": "Baghdad", "type": "text" },
                { "key": "district", "value": "Karkh", "type": "text" },
                { "key": "address", "value": "Al Mansour, Street 10", "type": "text" },
                { "key": "latitude", "value": "33.3128", "type": "text" },
                { "key": "longitude", "value": "44.3615", "type": "text" },
                { "key": "status", "value": "active", "type": "text" },
                { "key": "principalName", "value": "Ahmed Mohammed", "type": "text" },
                { "key": "adminPhone", "value": "7701234567", "type": "text" },
                { "key": "authorizedPersonName", "value": "Ali Hassan", "type": "text" },
                { "key": "authorizedPersonPhone", "value": "7712345678", "type": "text" },
                { "key": "notes", "value": "Main branch", "type": "text" },
                { "key": "attachment", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/api/schools"
          }
        },
        {
          "name": "PUT /api/schools/{school}",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "status", "value": "inactive", "type": "text" },
                { "key": "notes", "value": "Updated school info", "type": "text" },
                { "key": "attachment", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/api/schools/{{school_id}}"
          }
        },
        {
          "name": "DELETE /api/schools/{school} (admin only)",
