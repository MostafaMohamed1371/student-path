APP_NAME=student-path
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google Places (optional) — /api/places/* proxy
GOOGLE_PLACES_API_KEY=

# Standing Tech SMS / WhatsApp (https://gateway.standingtech.com/api/v4/sms/send)
# If BEARER_TOKEN is empty, the app uses FakeSmsSender (log only) so send-otp still succeeds.
STANDINGTECH_SMS_URL=https://gateway.standingtech.com/api/v4/sms/send
STANDINGTECH_BEARER_TOKEN=
STANDINGTECH_SENDER_ID=
STANDINGTECH_TYPE=whatsapp
STANDINGTECH_LANG=ar
# canonical = full international digits as stored (e.g. 9665XXXXXXXX). composed = prefix+trunk+national.
STANDINGTECH_RECIPIENT_FORMAT=canonical
STANDINGTECH_RECIPIENT_PREFIX=
STANDINGTECH_MOBILE_TRUNK=
STANDINGTECH_STRIP_INTERNATIONAL_PREFIX=964
STANDINGTECH_MOCK=true
STANDINGTECH_TIMEOUT=15

# Web dashboard (Blade login + session). Subtitle under "Welcome" on /login
DASHBOARD_BRAND="${APP_NAME}"
DASHBOARD_SEED_PHONE=7701234567
DASHBOARD_SEED_PASSWORD=12345678

# Qi Card (Iraq) — wallet top-up. When enabled with default QI_CARD_BLOCK_DIRECT_RECHARGE=true,
# POST /api/wallet/recharge is rejected; use POST /api/wallet/payments/qicard/init then open form_url.
# Docs: https://developers-gate.qi.iq — set absolute callback URLs in production (tunnel or public APP_URL).
QI_CARD_ENABLED=false
QI_CARD_BLOCK_DIRECT_RECHARGE=true
QI_CARD_API_HOST=
QI_CARD_USERNAME=
QI_CARD_PASSWORD=
QI_CARD_TERMINAL_ID=
QI_CARD_TIMEOUT=30
# Optional overrides (otherwise APP_URL + paths from config/qicard.php)
# QI_CARD_FINISH_PAYMENT_URL=https://api.example.com/api/wallet/payments/qicard/finish
# QI_CARD_NOTIFICATION_URL=https://api.example.com/api/webhooks/qicard

# Optional fixed OTP (e.g. 0000) in any environment: send stores this code; verify accepts it for login without SMS. Leave empty for random OTPs. PHPUnit forces this empty so tests stay valid.
# OTP_STATIC_CODE=0000
# Seconds between send-otp for the same phone. Default 0 = no wait. Set e.g. 30 in production to limit repeated SMS.
# OTP_RESEND_SECONDS=0
# Route throttle for POST /api/auth/send-otp (per phone + per IP, per minute). Was 5/IP and caused "Too Many Attempts."
# OTP_SEND_THROTTLE_PER_PHONE_PER_MINUTE=120
# OTP_SEND_THROTTLE_PER_IP_PER_MINUTE=300
